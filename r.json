{
  "id": "6a32ad689f4305a87ab86200",
  "ruleId": "GT_RULE_01_MACD_EMA_STACK_42_38_M5_V1",
  "ruleName": "GT-RULE-01 MACD EMA_STACK 42/38 M5",
  "fullRuleConditions": {
    "ruleCode": "GT_RULE_01_MACD_EMA_STACK",
    "version": "1.0.0",
    "status": "RESEARCH_ONLY",
    "productionStatus": "NOT_ACTIVE",
    "description": "MACD and EMA_STACK agreement rule. Opens one order when MACD and EMA_STACK direction match and both strengths equal 1.0. Uses Close price as entry because indicators update on candle close. Manages one active order at a time using TP, SL, TD violation, MACD strength violation, and EMA strength violation.",
    "input": {
      "sourceType": "CSV",
      "requiredColumns": [
        "DateTime",
        "Open",
        "High",
        "Low",
        "Close",
        "MACD_TD",
        "MACD_TS",
        "EMA_STACK_TD",
        "EMA_STACK_TS"
      ],
      "datetimeColumn": "DateTime",
      "ohlcColumns": {
        "open": "Open",
        "high": "High",
        "low": "Low",
        "close": "Close"
      },
      "indicatorColumns": {
        "macdDirection": "MACD_TD",
        "macdStrength": "MACD_TS",
        "emaStackDirection": "EMA_STACK_TD",
        "emaStackStrength": "EMA_STACK_TS"
      }
    },
    "parameters": {
      "tpPip": 42,
      "slPip": 38,
      "timeframe": "M5",
      "entryPriceSource": "Close",
      "maxOpenOrders": 1,
      "maxHoldingCandles": null,
      "sameCandleTpSlCollectedPips": 0
    },
    "pipConfig": {
      "pipSizeMode": "AUTO_BY_PAIR",
      "jpyPairPipSize": 0.01,
      "nonJpyPairPipSize": 1.0e-4,
      "pipToPriceFormula": "pip_value * pip_size"
    },
    "normalization": {
      "directionValues": ["UP", "DOWN", "NO_SIGNAL"],
      "directionNormalization": "strip_spaces_and_uppercase",
      "strengthNormalization": "float"
    },
    "entryLogic": {
      "manageOrderFromNextRow": true,
      "conditions": [
        {
          "name": "direction_agreement",
          "condition": "MACD_TD == EMA_STACK_TD"
        },
        {
          "name": "macd_strength_full",
          "condition": "MACD_TS <= 1.0 && MACD_TS >= 0.0"
        },
        {
          "name": "ema_stack_strength_full",
          "condition": "EMA_STACK_TS <= 1.0 && EMA_STACK_TS >= 0.0"
        },
        {
          "name": "no_signal_block",
          "condition": "MACD_TD != NO_SIGNAL AND EMA_STACK_TD != NO_SIGNAL"
        }
      ],
      "sideMapping": {
        "UP": "UP",
        "DOWN": "DOWN"
      },
      "skipConditions": [
        {
          "name": "no_signal",
          "condition": "MACD_TD == NO_SIGNAL OR EMA_STACK_TD == NO_SIGNAL",
          "action": "SKIP"
        },
        {
          "name": "direction_not_equal",
          "condition": "MACD_TD != EMA_STACK_TD",
          "action": "SKIP"
        }
      ]
    },
    "priceLevelLogic": {
      "upOrder": {
        "tpPrice": "entry_price + tp_pip * pip_size",
        "slPrice": "entry_price - sl_pip * pip_size"
      },
      "downOrder": {
        "tpPrice": "entry_price - tp_pip * pip_size",
        "slPrice": "entry_price + sl_pip * pip_size"
      }
    },
    "executionLogic": {
      "sameEntryCandleExecution": false,
      "manageOrderFromNextRow": true,
      "priority": [
        {
          "order": 1,
          "name": "same_candle_tp_sl"
        },
        {
          "order": 2,
          "name": "take_profit"
        },
        {
          "order": 3,
          "name": "stop_loss"
        },
        {
          "order": 4,
          "name": "td_violation"
        },
        {
          "order": 5,
          "name": "macd_ts_violation"
        },
        {
          "order": 6,
          "name": "ema_stack_ts_violation"
        },
        {
          "order": 7,
          "name": "continue_order"
        }
      ]
    },
    "tpSlLogic": {
      "upOrder": {
        "tpHitCondition": "High >= tp_price",
        "slHitCondition": "Low <= sl_price"
      },
      "downOrder": {
        "tpHitCondition": "Low <= tp_price",
        "slHitCondition": "High >= sl_price"
      },
      "sameCandleTpSl": {
        "condition": "tp_hit == true AND sl_hit == true",
        "closeStatus": "HIT_TP_SL_IN_SAME_CANDLE",
        "activeOrder": false,
        "collectedPips": 0
      },
      "normalTakeProfit": {
        "closeStatus": "HIT_TP_WIN",
        "activeOrder": false,
        "collectedPipsFormula": "+tp_pip"
      },
      "normalStopLoss": {
        "closeStatus": "HIT_SL_LOSS",
        "activeOrder": false,
        "collectedPipsFormula": "-sl_pip"
      }
    },
    "violationLogic": {
      "tdViolation": {
        "condition": "MACD_TD != EMA_STACK_TD",
        "closePriceSource": "Close",
        "upOrderPipsFormula": "(Close - entry_price) / pip_size",
        "downOrderPipsFormula": "(entry_price - Close) / pip_size",
        "winStatus": "VIOLATE_TD_WIN",
        "lossStatus": "VIOLATE_TD_LOSS",
        "winCondition": "collected_pips > 0",
        "lossCondition": "collected_pips <= 0"
      }
    },
    "endOfFileLogic": {
      "description": "If CSV ends while an order is still active, close at final row Close.",
      "closePriceSource": "Close",
      "winStatus": "FORCE_CLOSE_AT_END_WIN",
      "lossStatus": "FORCE_CLOSE_AT_END_LOSS"
    },
    "output": {
      "tradeCsvColumns": [
        "rule_name",
        "pair",
        "timeframe",
        "order_id",
        "direction",
        "entry_datetime",
        "entry_index",
        "entry_price",
        "tp_pip",
        "sl_pip",
        "tp_price",
        "sl_price",
        "close_datetime",
        "close_index",
        "close_price",
        "close_status",
        "collected_pips",
        "cc",
        "entry_macd_td",
        "entry_macd_ts",
        "entry_ema_stack_td",
        "entry_ema_stack_ts",
        "close_macd_td",
        "close_macd_ts",
        "close_ema_stack_td",
        "close_ema_stack_ts"
      ]
    },
    "safety": {
      "brokerOrdersAllowed": false,
      "liveTradingAllowed": false,
      "researchOnly": true
    }
  },
  "createdAt": "2026-06-17T14:21:28.399Z",
  "updatedAt": "2026-06-17T14:21:28.399Z"
}
